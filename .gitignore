# --- Private / local-only ---
.env
.env.*
!.env.example
.env.local

# --- Source media (never commit originals) ---
Context and media/
portfolio_plan_v0.md

# --- Optimized assets (local cache; canonical copy in Supabase Storage) ---
public/assets/
preview/assets/

# --- Generated preview bundle (npm run preview:build) ---
preview/

# --- Build output ---
node_modules/
dist/
.astro/

# --- Agent / editor tooling (local only) ---
.agents/
.cursor/

# --- OS junk ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs & temp ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Archives & backups ---
*.tar.gz
*.zip

# --- Media pipeline artifacts ---
scripts/.media-inject.json
scripts/.hobby-manifest.json
scripts/.media-video-jobs.sh
scripts/.media-video.log

# --- LaTeX (CV source; served PDF syncs to Supabase) ---
/cv/
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
cv/*.out

# --- Deploy / test tooling ---
.vercel/
coverage/
test-results/
playwright-report/
playwright/.cache/

# --- TypeScript cache ---
*.tsbuildinfo
